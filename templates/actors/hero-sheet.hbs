    {{! ===========================
    TAB: NOTES
    =========================== }}
    <div class="tab" data-group="primary-tabs" data-tab="notes">
      <h2>Notes</h2>
      <textarea name="system.notes" rows="16" placeholder="Adventure notes...">{{system.notes}}</textarea>
      <section class="level-section">
        <label class="section-title">Level:</label>
        {{#each levels as |L|}}
        <div class="level-row">
          <input type="checkbox" name="system.levels.{{L.main}}" {{checked (lookup @root.system.levels L.main)}} />
          <span>Lvl {{L.lvl}}</span>
          {{#each L.subs as |sub|}}
          <input type="checkbox" name="system.levels.{{sub}}" {{checked (lookup @root.system.levels sub)}} />
          {{/each}}
        </div>
        {{/each}}
      </section>

    </div>

